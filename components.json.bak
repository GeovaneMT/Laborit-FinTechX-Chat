{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/presentation/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@ui",
    "utils": "@presentation/lib/utils",
    "ui": "@shadcn",
    "lib": "@presentation/lib",
    "hooks": "@pattern/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@magicui": "https://magicui.design/r/{name}.json",
    "@diceui": "https://diceui.com/r/{name}.json"
  }
}
