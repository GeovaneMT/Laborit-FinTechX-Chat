{
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "node",
      "vitest",
      "vitest/globals",
      "@types/react",
      "@types/react-dom"
    ],
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "allowJs": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@app/*": [
        "./src/app/*"
      ],
      "@mocks/*": [
        "./src/mocks/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@utils/*": [
        "./src/core/utils/*"
      ],
      "@infra/*": [
        "./src/infra/*"
      ],
      "@env/*": [
        "./src/infra/env/*"
      ],
      "@actions/*": [
        "./src/infra/server/actions/*"
      ],
      "@http/*": [
        "./src/http/*"
      ],
      "@errors/*": [
        "./src/infra/errors/*"
      ],
      "@tanstack/*": [
        "./src/infra/data/tanstack/*"
      ],
      "@queries/*": [
        "./src/infra/data/tanstack/react-query/queries/*"
      ],
      "@queryFn/*": [
        "./src/infra/data/query-functions/*"
      ],
      "@mutations/*": [
        "./src/infra/data/mutations/*"
      ],
      "@presentation/*": [
        "./src/presentation/*"
      ],
      "@features/*": [
        "./src/presentation/features/*"
      ],
      "@layouts/*": [
        "./src/presentation/layouts/*"
      ],
      "@pattern/*": [
        "./src/presentation/pattern/*"
      ],
      "@contexts/*": [
        "./src/presentation/pattern/contexts/*"
      ],
      "@models/*": [
        "./src/presentation/models/*"
      ],
      "@styles/*": [
        "./src/presentation/styles/*"
      ],
      "@schemas/*": [
        "./src/presentation/schemas/*"
      ],
      "@providers/*": [
        "./src/presentation/providers/*"
      ],
      "@zustand/*": [
        "./src/infra/stores/*"
      ],
      "@ui/*": [
        "./src/presentation/ui/*"
      ],
      "@shadcn/*": [
        "./src/presentation/ui/shadcn/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vitest.config.mts",
    "tsconfig.json",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}